generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  name         String?
  createdAt    DateTime      @default(now())
  learnedWords       LearnedWord[]
  progress           Progress[]
  quizResults        QuizResult[]
  flashcardPositions FlashcardPosition[]
}

model LearnedWord {
  id        String   @id @default(cuid())
  userId    String
  word      String
  tab       String
  learnedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, word, tab])
  @@index([userId, tab])
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  tab         String
  dayIndex    Int
  slot        String
  completed   Boolean  @default(true)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, tab, dayIndex, slot])
  @@index([userId, tab])
}

model QuizResult {
  id         String   @id @default(cuid())
  userId     String
  tab        String
  dayIndex   Int
  score      Int
  total      Int
  percentage Float
  takenAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, tab])
}

model FlashcardPosition {
  id           String   @id @default(cuid())
  userId       String
  tab          String
  vocabDay     Int      @default(-1)
  currentIndex Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, tab, vocabDay])
  @@index([userId])
}
